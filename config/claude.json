{
  "mcpServers": {
    "zowe-mcp-server": {
      "command": "npx",
      "args": ["-y", "@gestell/zowe-mcp"],
      "env": {
        "ZOWE_MCP_MOCK": "false",
        "ZOWE_CLI_HOME": "/Users/my-name/.zowe",
        "ZOWE_MCP_TSO_ACCOUNT": "ACCT001",
        "ZOWE_MCP_BASE_PROFILE": "project_base",
        "ZOWE_MCP_ZOSMF_PROFILE": "zosmf",
        "ZOWE_MCP_TSO_PROFILE": "tso",
        "ZOWE_MCP_EXEC_TIMEOUT_MS": "300000",
        "ZOWE_MCP_INLINE_WAIT_MS": "10000",
        "ZOWE_MCP_WAIT_TOOL_MAX_WAIT_MS": "55000",
        "ZOWE_MCP_WAIT_TOOL_POLL_INTERVAL_MS": "2000"
      }
    }
  },
  "preferences": {
    "coworkScheduledTasksEnabled": false,
    "ccdScheduledTasksEnabled": false,
    "coworkWebSearchEnabled": true,
    "sidebarMode": "chat"
  }
}